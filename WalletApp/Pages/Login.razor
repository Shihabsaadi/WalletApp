@page "/login"
@using WalletApp.Services
@inject AuthService Auth
@inject NavigationManager Nav

<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#4F46E5,#7C3AED)">
    <div style="background:#fff;border-radius:20px;padding:40px;width:380px;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,.2)">
        <div style="font-size:52px;margin-bottom:12px">💰</div>
        <div style="font-size:24px;font-weight:700;margin-bottom:6px">My Wallet</div>
        <div style="font-size:14px;color:#6B7280;margin-bottom:32px">Track your money. Stay in control.</div>

        <button @onclick="LoginWithGoogle" style="display:flex;align-items:center;justify-content:center;gap:12px;width:100%;padding:14px;border:1.5px solid #E5E7EB;border-radius:10px;background:#fff;font-size:15px;font-weight:500;cursor:pointer;transition:all .15s">
            <svg width="20" height="20" viewBox="0 0 48 48">
                <path fill="#FFC107" d="M43.6 20H24v8h11.3C33.6 33.1 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3 0 5.8 1.1 7.9 3l5.7-5.7C34.1 6.5 29.3 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20c11 0 20-8 20-20 0-1.3-.1-2.7-.4-4z" />
                <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.5 15.1 18.9 12 24 12c3 0 5.8 1.1 7.9 3l5.7-5.7C34.1 6.5 29.3 4 24 4c-7.6 0-14.2 4.4-17.7 10.7z" />
                <path fill="#4CAF50" d="M24 44c5.2 0 9.9-1.9 13.5-5l-6.2-5.2C29.4 35.5 26.8 36 24 36c-5.2 0-9.6-2.9-11.3-7.1l-6.5 5C9.9 39.6 16.5 44 24 44z" />
                <path fill="#1976D2" d="M43.6 20H24v8h11.3c-.9 2.4-2.5 4.4-4.6 5.8l6.2 5.2C40.8 35.5 44 30.2 44 24c0-1.3-.1-2.7-.4-4z" />
            </svg>
            Continue with Google
        </button>

        <div style="margin-top:24px;font-size:12px;color:#9CA3AF">
            Your data is stored privately in your own Google Sheet.<br />We never store your data on any server.
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        if (Auth.IsLoggedIn)
            Nav.NavigateTo("/", forceLoad: false);
    }

    void LoginWithGoogle()
    {
        var url = Auth.GetGoogleLoginUrl();
        Nav.NavigateTo(url, forceLoad: true);
    }
}