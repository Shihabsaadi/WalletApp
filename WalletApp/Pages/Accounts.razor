@page "/accounts"
@using WalletApp.Services
@using WalletApp.Models
@inject GoogleSheetsService Sheets
@inject NavigationManager Nav

<div style="max-width:700px;margin:0 auto">

    <!-- Add new account button -->
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
        <div>
            <div style="font-size:20px;font-weight:700">My Accounts</div>
            <div style="font-size:13px;color:#6B7280;margin-top:2px">Manage your wallets and bank accounts</div>
        </div>
        <button class="btn btn-primary" @onclick="ShowAddForm">
            + Add Account
        </button>
    </div>

    <!-- Add / Edit Form -->
    @if (showForm)
    {
        <div style="background:#fff;border-radius:14px;border:1px solid #E5E7EB;padding:24px;margin-bottom:24px;box-shadow:0 2px 8px rgba(0,0,0,.06)">
            <div style="font-size:16px;font-weight:600;margin-bottom:18px">
                @(editingAccount == null ? "➕ New Account" : "✏️ Edit Account")
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Account Name</label>
                    <input class="form-control" type="text" placeholder="e.g. Cash, bKash, Dutch Bangla"
                           @bind="formName" />
                </div>
                <div class="form-group">
                    <label class="form-label">Account Type</label>
                    <select class="form-control" @bind="formType">
                        <option value="Cash">💵 Cash</option>
                        <option value="Bank">🏦 Bank Account</option>
                        <option value="Savings">🏧 Savings Account</option>
                        <option value="Salary">💰 Salary Account</option>
                        <option value="MobileBanking">📱 Mobile Banking</option>
                        <option value="Investment">📈 Investment</option>
                        <option value="CreditCard">💳 Credit Card</option>
                        <option value="Other">📂 Other</option>
                    </select>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">
                        @(editingAccount == null ? "Opening Balance (৳)" : "Current Balance (৳)")
                    </label>
                    <input class="form-control" type="number" step="0.01" placeholder="0.00"
                           @bind="formBalance" />
                </div>
                <div class="form-group">
                    <label class="form-label">Currency</label>
                    <select class="form-control" @bind="formCurrency">
                        <option value="BDT">BDT — Bangladeshi Taka</option>
                        <option value="USD">USD — US Dollar</option>
                        <option value="EUR">EUR — Euro</option>
                        <option value="GBP">GBP — British Pound</option>
                        <option value="SAR">SAR — Saudi Riyal</option>
                        <option value="AED">AED — UAE Dirham</option>
                    </select>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(formError))
            {
                <div style="background:#FEE2E2;color:#DC2626;padding:10px 14px;border-radius:8px;margin-bottom:14px;font-size:13px">
                    @formError
                </div>
            }

            <div style="display:flex;gap:10px;margin-top:4px">
                <button class="btn btn-primary" @onclick="SaveAccount" disabled="@saving">
                    @(saving ? "Saving..." : editingAccount == null ? "Create Account" : "Save Changes")
                </button>
                <button class="btn btn-outline" @onclick="CancelForm">Cancel</button>
            </div>
        </div>
    }

    <!-- Loading -->
    @if (loading)
    {
        <div style="text-align:center;padding:60px">
            <div style="font-size:36px;margin-bottom:12px">⏳</div>
            <div style="color:#6B7280;font-size:14px">Loading accounts...</div>
        </div>
    }
    else if (!accounts.Any())
    {
        <!-- Empty state -->
        <div style="text-align:center;padding:60px;background:#fff;border-radius:14px;border:1px solid #E5E7EB">
            <div style="font-size:48px;margin-bottom:14px">🏦</div>
            <div style="font-size:17px;font-weight:600;margin-bottom:6px">No accounts yet</div>
            <div style="font-size:13px;color:#6B7280;margin-bottom:20px">Add your first account to start tracking money</div>
            <button class="btn btn-primary" @onclick="ShowAddForm">+ Add Your First Account</button>
        </div>
    }
    else
    {
        <!-- Total balance bar -->
        <div style="background:linear-gradient(135deg,#4F46E5,#7C3AED);border-radius:14px;padding:20px 24px;margin-bottom:20px;color:#fff">
            <div style="font-size:13px;opacity:.8;margin-bottom:4px">Total Balance Across All Accounts</div>
            <div style="font-size:32px;font-weight:700">৳@accounts.Sum(a => a.Balance).ToString("N2")</div>
            <div style="font-size:12px;opacity:.7;margin-top:4px">@accounts.Count account@(accounts.Count == 1 ? "" : "s")</div>
        </div>

        <!-- Account list -->
        <div style="display:flex;flex-direction:column;gap:12px">
            @foreach (var account in accounts)
            {
                <div style="background:#fff;border-radius:14px;border:1px solid #E5E7EB;padding:18px 20px;box-shadow:0 1px 4px rgba(0,0,0,.05);display:flex;align-items:center;gap:16px">

                    <!-- Icon -->
                    <div style="width:48px;height:48px;border-radius:12px;background:@GetAccountColor(account.Type);display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0">
                        @GetAccountIcon(account.Type)
                    </div>

                    <!-- Info -->
                    <div style="flex:1;min-width:0">
                        <div style="font-size:16px;font-weight:600;color:#111827">@account.Name</div>
                        <div style="font-size:12px;color:#6B7280;margin-top:2px">
                            @account.Type • @account.Currency • Added @account.CreatedAt.ToString("dd MMM yyyy")
                        </div>
                    </div>

                    <!-- Balance -->
                    <div style="text-align:right;flex-shrink:0">
                        <div style="font-size:20px;font-weight:700;color:@(account.Balance >= 0 ? "#4F46E5" : "#DC2626")">
                            ৳@account.Balance.ToString("N2")
                        </div>
                        <div style="font-size:11px;color:#9CA3AF;margin-top:2px">Current balance</div>
                    </div>

                    <!-- Actions -->
                    <div style="display:flex;gap:6px;flex-shrink:0">
                        <button class="btn-icon" title="View transactions"
                                @onclick='() => Nav.NavigateTo($"/transactions?account={account.AccountId}")'>
                            📋
                        </button>
                        <button class="btn-icon" title="Edit account"
                                @onclick="() => StartEdit(account)">
                            ✏️
                        </button>
                        <button class="btn-icon" title="Delete account"
                                style="background:#FEE2E2"
                                @onclick="() => ConfirmDelete(account)">
                            🗑️
                        </button>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Delete confirmation modal -->
    @if (accountToDelete != null)
    {
        <div style="position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:200;display:flex;align-items:center;justify-content:center;padding:20px">
            <div style="background:#fff;border-radius:16px;padding:28px;max-width:400px;width:100%;box-shadow:0 20px 60px rgba(0,0,0,.2)">
                <div style="font-size:36px;text-align:center;margin-bottom:12px">⚠️</div>
                <div style="font-size:17px;font-weight:600;text-align:center;margin-bottom:8px">Delete Account?</div>
                <div style="font-size:14px;color:#6B7280;text-align:center;margin-bottom:24px">
                    Are you sure you want to delete <strong>@accountToDelete.Name</strong>?
                    This will not delete existing transactions.
                </div>
                <div style="display:flex;gap:10px">
                    <button class="btn btn-danger" style="flex:1;justify-content:center"
                            @onclick="DeleteAccount" disabled="@saving">
                        @(saving ? "Deleting..." : "Yes, Delete")
                    </button>
                    <button class="btn btn-outline" style="flex:1;justify-content:center"
                            @onclick="() => accountToDelete = null">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    }

</div>

@code {
    List<Account> accounts = new();
    bool loading = true;
    bool showForm = false;
    bool saving = false;
    string formError = "";

    // Form fields
    string formName = "";
    string formType = "Cash";
    decimal formBalance = 0;
    string formCurrency = "BDT";

    Account? editingAccount = null;
    Account? accountToDelete = null;

    protected override async Task OnInitializedAsync()
        => await LoadAccounts();

    async Task LoadAccounts()
    {
        loading = true;
        accounts = await Sheets.GetAccountsAsync();
        loading = false;
    }

    void ShowAddForm()
    {
        editingAccount = null;
        formName = "";
        formType = "Cash";
        formBalance = 0;
        formCurrency = "BDT";
        formError = "";
        showForm = true;
    }

    void StartEdit(Account account)
    {
        editingAccount = account;
        formName = account.Name;
        formType = account.Type;
        formBalance = account.Balance;
        formCurrency = account.Currency;
        formError = "";
        showForm = true;

        // Scroll to top so form is visible
        StateHasChanged();
    }

    void CancelForm()
    {
        showForm = false;
        editingAccount = null;
        formError = "";
    }

    async Task SaveAccount()
    {
        if (string.IsNullOrWhiteSpace(formName))
        {
            formError = "Please enter an account name.";
            return;
        }

        saving = true;
        formError = "";

        if (editingAccount == null)
        {
            // Create new account
            var newAccount = new Account
            {
                Name = formName.Trim(),
                Type = formType,
                Balance = formBalance,
                Currency = formCurrency,
                CreatedAt = DateTime.Now
            };
            await Sheets.AddAccountAsync(newAccount);
        }
        else
        {
            // Update existing — update balance directly in sheet
            await Sheets.UpdateAccountBalanceAsync(editingAccount.AccountId, formBalance);
            // Also update name/type if needed via a full row update
            await Sheets.UpdateAccountAsync(editingAccount.AccountId, formName, formType, formBalance, formCurrency);
        }

        saving = false;
        showForm = false;
        editingAccount = null;
        await LoadAccounts();
    }

    void ConfirmDelete(Account account)
        => accountToDelete = account;

    async Task DeleteAccount()
    {
        if (accountToDelete == null) return;
        saving = true;
        await Sheets.DeleteAccountAsync(accountToDelete.AccountId);
        saving = false;
        accountToDelete = null;
        await LoadAccounts();
    }

    string GetAccountIcon(string type) => type switch
    {
        "Cash" => "💵",
        "Bank" => "🏦",
        "Savings" => "🏧",
        "Salary" => "💰",
        "MobileBanking" => "📱",
        "Investment" => "📈",
        "CreditCard" => "💳",
        _ => "📂"
    };

    string GetAccountColor(string type) => type switch
    {
        "Cash" => "#DCFCE7",
        "Bank" => "#DBEAFE",
        "Savings" => "#EDE9FE",
        "Salary" => "#FEF3C7",
        "MobileBanking" => "#FCE7F3",
        "Investment" => "#D1FAE5",
        "CreditCard" => "#FEE2E2",
        _ => "#F3F4F6"
    };
}